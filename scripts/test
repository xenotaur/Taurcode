#!/usr/bin/env bash
set -euo pipefail

echo "Testing taurcode ..."

# Run tests against the src/ layout from a fresh checkout, even before an
# editable install has added the package to site-packages. Preserve any caller
# supplied PYTHONPATH entries after the repository source path.
export PYTHONPATH="src${PYTHONPATH:+:${PYTHONPATH}}"

if [ "$#" -eq 0 ]; then
    set -x
    python -m unittest discover -b -s tests -p "*_test.py"
elif [ -d "$1" ]; then
    set -x
    python -m unittest discover -b -s "$1" -p "*_test.py"
elif [ -f "$1" ]; then
    module="${1%.py}"
    module="${module#./}"
    module="${module//\//.}"
    set -x
    python -m unittest -b "$module"
else
    set -x
    python -m unittest -b "$@"
fi

{ set +x; } 2>/dev/null
echo