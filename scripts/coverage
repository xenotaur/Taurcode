#!/bin/bash
set -euo pipefail

echo "Running coverage..."
set -x
PYTHONPATH=src python - <<'PY'
import sys
import unittest

suite = unittest.TestLoader().discover("tests", pattern="*_test.py")
count = suite.countTestCases()
if count == 0:
    print("ERROR: discovered 0 tests with pattern *_test.py under tests/", file=sys.stderr)
    raise SystemExit(2)
print(f"Discovered {count} tests.")
PY
PYTHONPATH=src python -m coverage run -m unittest discover -s tests -p "*_test.py"
python -m coverage report -m
